# Copy this file to `.env` in the repository root (next to README.md) and fill in values.
# `kalshi_ws` loads `.env` from the current working directory — run it from the repo root.

# Required for REST and WebSocket clients
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Demo: https://demo-api.kalshi.co/trade-api/v2  |  Prod: https://api.elections.kalshi.com/trade-api/v2
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Optional WebSocket overrides (defaults are usually fine)
# KALSHI_WS_URL=
# KALSHI_WS_OUT_DIR=data/kalshi/ws
# KALSHI_WS_TRADE_BUFFER=5000

# Optional: JSONL path for kalshi_as --sample-contracts (hypothetical orders only)
# KALSHI_AS_SAMPLE_ORDERS=data/kalshi/as_sample_orders.jsonl
